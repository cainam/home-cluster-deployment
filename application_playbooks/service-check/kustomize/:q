apiVersion: batch/v1
kind: CronJob
metadata:
  name: {{ kustom.name }}
spec:
  schedule: "*/5 * * * *" # Runs every 5 minutes
  jobTemplate:
    spec:
      template:
        spec:
          serviceAccountName: registry-checker-sa
          containers:
          - name: checker
            image: {{ kustom.image }}
            command:
            - /bin/sh
            - -c
            - |
              # 1. Check if the registry is up (returns 200)
              # Replace with your actual registry health endpoint
              STATUS=$(curl -o /dev/null -s -w "%{http_code}" https://10.10.10.10/v2/)
              
              if [ "$STATUS" -eq 200 ]; then
                VAL="available"
              else
                VAL="unavailable"
              fi

              echo "Registry status is $VAL ($STATUS). Updating ConfigMap..."

              APISERVER="https://kubernetes.default.svc"
              SERVICEACCOUNT="/var/run/secrets/kubernetes.io/serviceaccount"
              NAMESPACE=$(cat ${SERVICEACCOUNT}/namespace)
              TOKEN=$(cat ${SERVICEACCOUNT}/token)
              CACERT=${SERVICEACCOUNT}/ca.crt

              # 2. Execute the Patch
              curl -s --cacert ${CACERT} \
                   -X PATCH \
                   -H "Authorization: Bearer ${TOKEN}" \
                   -H "Content-Type: application/merge-patch+json" \
                   --data "{\"data\":{\"registry\":{\"state\": \"$VAL\"}}}" \
                   "${APISERVER}/api/v1/namespaces/${NAMESPACE}/configmaps/{{ kustom.name }}"

              # 2. Patch the ConfigMap
              kubectl patch configmap your-config-map-name \
                --type merge \
                -p "{\"data\":{\"registry_status\":\"$VAL\"}}"
          restartPolicy: OnFailure
