additional_roles:
- repo: https://github.com/cainam/ansible_helper_playbooks.git
  role: shared_helper
- repo: https://github.com/cainam/gentoo-image-builder.git
  role: gentoo-image-builder

auto_silent: true
own_git_url: https://github.com/cainam/home-cluster-deployment.git
applications_git: https://github.com/cainam/application-specifics.git
timezone: Europe/Amsterdam
path: /usr/local/bin/:/usr/sbin:/usr/bin:/sbin:/bin

gluster_directory: /data/gluster
local_disk_directory: /data/disks
remote_temp: /data/tmp
default_boot_device: /dev/mmcblk0p1

registry_host: myregistry.adm13
registry: {{ registry_host }}:443
shared_mounts: /shared
default_platform: arm64
cert_path: /data/mine/certs
system_local_certs: /usr/local/share/ca-certificates

my_certs:
  local_ca_files:
  - "root-ca.crt"
  - "intermediate-ca.crt"
  certs:
  - name: {{ registry_host }}
    dest: /shared/registry/certs
  conf:
    ca_own_root: true
    ca_openssl_path: "{{ cert_path }}"
    ca_common_name: FreeAsABird
    ca_country_name: XX
    ca_passphrase: "{{ cert_pass }}"
    ca_organization_name: FreeAsABird
    ca_organizational_unit_name: Anarchists
    ca_state_or_province_name: Some-State
    ca_email_address: a.b@c.de

net:
  domain_external: adm13.dnshome.de
  base_domain: my-lb.adm13
  cidr: 10.10.10.0/24
  virtual_ips:
  - ip: 10.10.10.10
    names: ["k8s.adm13", "{{ registry_host }}", "podman.adm13"]
  open_services:
  - oauth2-proxy
  - hydra
  - idp
  routes:
  - domain: my-lb.adm13
    gateway: traefik
    external_port: 44354
    endpointIP: 192.168.4.100
  - domain: ha.my-lb.adm13
    gateway: istio
    namespace: istio-ingress
    endpointIP: 192.168.4.101

oauth2_path: /oauth2-hydra

volumes_to_exempt:
  - registry

# supported storage types are longhorn, gluster and local
default_storage_type: gluster

# K8s
k8s:
  mutate: valmut
  external_coredns_ip: 192.168.4.111
  podSubnet: 10.244.0.0/16

gateway_install:
  deployment_type: kustomize
  flags: ['certs']
  images:
  - proxyv2
  kustom:
    application: gateway
