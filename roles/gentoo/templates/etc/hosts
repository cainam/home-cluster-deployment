# IPv4 and IPv6 localhost aliases
127.0.0.1	localhost
#::1		localhost

{% for hname in hostvars +%}
{% if hname != 'localhost' %}
{{ hostvars[hname].my_cluster_ip }} {{ hostvars[hname].inventory_hostname }} {{ hostvars[hname].inventory_hostname | split('.') | first }} {% if hostvars[hname].alt_names is defined and 'gentoo-binhost' in hostvars[hname].alt_names %}gentoo-binhost{% endif %}
{% endif %}
{% endfor %}

{% for l in net.virtual_ips %}
{{ l.ip }} {% for n in l.names %}{{ n }} {%endfor %}
{% endfor %}

{% for route in net.routes %}
{{ route.endpointIP }} {{ route.domain }}
{% endfor -%}
