software:
  flannel:
    version: v0.28.7
    installed:
      pattern: "flannel:"
    latest:
      type: github
      params:
        repo: flannel-io/flannel
  flannel-cni-plugin:
    version: v1.9.1-flannel2
    installed:
      pattern: "lannel-cni-plugin:"
    latest:
      type: github
      params:
        repo: flannel-io/cni-plugin
  traefik:
    version: v3.7.6
    installed:
      pattern: "traefik"
    latest:
      type: github
      params:
        repo: traefik/traefik
  istio:
    version: 1.30.2
    installed:
      pattern: "istio"
    latest:
      type: github
      params:
        repo: istio/istio
  oauth2-proxy:
    version: v7.15.3
    installed:
      pattern: "oauth2-proxy:"
    latest:
      type: github
      params:
        repo: oauth2-proxy/oauth2-proxy
  zigbee2mqtt:
    version: 2.12.1
    latest:
      type: github
      params:
        repo: koenkk/zigbee2mqtt
  mosquitto:
    version: v2.1.2
    max_entries: 2
    latest:
      type: github-tags
      params:
        repo: eclipse-mosquitto/mosquitto
        arch: arm64
  home-assistant:
    version: "2026.6.3"
    installed:
      pattern: "home-assistant:"
    latest:
      type: dockerhub
      params:
        repo: homeassistant/home-assistant
        arch: arm64
  registry:
    version: v3.1.1
    latest:
      type: dockerhub
      params:
        repo: library/registry
        arch: arm64
  trivy:
    version: v0.72.0
    max_entries: 3
    latest:
      type: github
      params:
        repo: aquasecurity/trivy
  kube-network-policies:
    version: v1.1.0
    max_entries: 3
    latest:
      type: github
      params:
        repo: kubernetes-sigs/kube-network-policies
  etcd:
    version: v3.6.12
    max_entries: 3
    latest:
      type: github
      params:
        repo: etcd-io/etcd
  kubernetes:
    version: 1.36.1
    max_entries: 3
    latest:
      type: gentoo
      params:
        repo: sys-cluster/kubeadm
  postgresql:
    version: 18.4
    max_entries: 4
    latest:
      type: gentoo
      params:
        repo: dev-db/postgresql
  descheduler:
    version: "v0.36.0"
    latest:
      type: github
      params: 
        repo: kubernetes-sigs/descheduler
  hydra:
    version: v26.2.0
    latest:
      type: github
      params:
        repo: ory/hydra
  longhorn:
    version: v1.11.2
    installed:
      pattern: "longhorn-ui:"
    latest:
      type: github
      params:
        repo: longhorn/longhorn
